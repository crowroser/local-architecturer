{
  "name": "local-architecturer",
  "version": "0.4.0",
  "description": "Local architecture analyzer for pnpm monorepos and Docker configs",
  "bin": {
    "arch-viz": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fast-glob": "^3.3.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "architecture",
    "analyzer",
    "monorepo",
    "pnpm",
    "docker",
    "mcp",
    "cli",
    "visualization",
    "react-flow",
    "dependency-graph"
  ],
  "author": "crowroser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crowroser/local-architecturer.git"
  },
  "homepage": "https://github.com/crowroser/local-architecturer#readme",
  "bugs": {
    "url": "https://github.com/crowroser/local-architecturer/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
