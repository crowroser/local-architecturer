# local-architecturer configuration
# Copy to `.env` and adjust. All values are optional.

# --- Server / ports ---
# Web dashboard + REST API port (default 4000)
ARCHVIZ_PORT=4000
# MCP HTTP server port (default 3001)
ARCHVIZ_MCP_PORT=3001
# Bind host. 127.0.0.1 = local-only (recommended). Use 0.0.0.0 to expose.
ARCHVIZ_HOST=127.0.0.1

# --- Caching ---
# Scan cache TTL in milliseconds (default 30000)
ARCHVIZ_CACHE_TTL=30000
# Secret required by POST /api/cache/invalidate (set a long random string).
# If unset, cache invalidation is DISABLED for safety.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ARCHVIZ_CACHE_SECRET=

# --- Git history (time-travel) ---
ARCHVIZ_GIT_TIMEOUT=10000
ARCHVIZ_GIT_SHORT_TIMEOUT=5000
ARCHVIZ_MAX_COMMITS=500

# --- AI review engine ---
# Provider: ollama | openrouter | lmstudio
ARCHVIZ_PROVIDER=ollama
ARCHVIZ_MODEL=qwen2.5
# Custom base URL (e.g. remote Ollama, OpenRouter proxy)
ARCHVIZ_BASE_URL=
# API key for OpenRouter / hosted providers. NEVER put this in CLI args.
ARCHVIZ_OPENROUTER_API_KEY=
# LLM request timeout in ms (default 60000)
ARCHVIZ_AI_TIMEOUT=60000

# --- Observability ---
# error | warn | info | debug
ARCHVIZ_LOG_LEVEL=info
